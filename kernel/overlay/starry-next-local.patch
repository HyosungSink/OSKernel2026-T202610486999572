+pub(crate) fn sys_readlinkat(
+    _dirfd: i32,
+    path: *const c_char,
+    buf: *mut c_char,
+    bufsiz: usize,
+) -> isize {
+    syscall_body!(sys_readlinkat, {
+        if buf.is_null() {
+            return Err(LinuxError::EFAULT);
+        }
+        let path_str = api::char_ptr_to_str(path)?;
+        let curr = current();
+        let target = match path_str {
+            "/proc/self/exe" => curr.name(),
+            _ => return Err(LinuxError::ENOENT),
+        };
+        let bytes = target.as_bytes();
+        let len = bytes.len().min(bufsiz);
+        unsafe {
+            core::ptr::copy_nonoverlapping(bytes.as_ptr(), buf as *mut u8, len);
+        }
+        Ok(len)
+    })
+}
+
+pub(crate) fn sys_faccessat(dirfd: i32, path: *const c_char, _mode: i32, _flags: i32) -> isize {
+    syscall_body!(sys_faccessat, {
+        let fd = api::sys_openat(dirfd, path, api::ctypes::O_RDONLY as i32, 0);
+        if fd < 0 {
+            return Err(LinuxError::try_from((-fd) as i32).unwrap_or(LinuxError::ENOENT));
+        }
+        let _ = api::sys_close(fd);
+        Ok(0)
+    })
+}
