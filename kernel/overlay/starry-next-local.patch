+pub(crate) fn sys_newfstatat(
+    dirfd: i32,
+    pathname: *const u8,
+    statbuf: *mut api::ctypes::stat,
+    flags: i32,
+) -> i32 {
+    syscall_body!(sys_newfstatat, {
+        if statbuf.is_null() {
+            return Err(LinuxError::EFAULT);
+        }
+
+        const AT_EMPTY_PATH: i32 = 0x1000;
+        let path = api::char_ptr_to_str(pathname as *const _)?;
+        if path.is_empty() {
+            if flags & AT_EMPTY_PATH == 0 {
+                return Err(LinuxError::EINVAL);
+            }
+            let res = unsafe { api::sys_fstat(dirfd, statbuf) };
+            if res < 0 {
+                return Err(LinuxError::try_from(-res).unwrap_or(LinuxError::EINVAL));
+            }
+            return Ok(0);
+        }
+
+        let fd = api::sys_openat(dirfd, pathname as *const _, api::ctypes::O_RDONLY as i32, 0);
+        if fd < 0 {
+            return Err(LinuxError::try_from(-fd).unwrap_or(LinuxError::ENOENT));
+        }
+        let res = unsafe { api::sys_fstat(fd, statbuf) };
+        let _ = api::sys_close(fd);
+        if res < 0 {
+            return Err(LinuxError::try_from(-res).unwrap_or(LinuxError::EINVAL));
+        }
+        Ok(0)
+    })
+}
